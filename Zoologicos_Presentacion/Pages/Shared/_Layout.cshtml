<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zoológicos</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Zoologicos_Presentacion.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-page="/Index">🐾 Zoológicos</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>

                        @if (Context.Session.GetString("UsuarioSede") != null)
                        {
                            <!-- ══ CATÁLOGOS BASE ══ -->
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">Catálogos</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Zoologicos">Zoológicos</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Especies">Especies</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Enfermedades">Enfermedades</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Visitantes">Visitantes</a></li>
                                </ul>
                            </li>

                            <!-- ══ INFRAESTRUCTURA ══ -->
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">Infraestructura</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Habitats">Hábitats</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Jaulas">Jaulas</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/ZonasPublicas">Zonas Públicas</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Areas">Áreas</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Inventarios">Inventarios</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Mantenimientos">Mantenimientos</a></li>
                                </ul>
                            </li>

                            <!-- ══ ANIMALES ══ -->
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">Animales</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Animales">Animales</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Alimentaciones">Alimentaciones</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Ingresos">Ingresos</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Reproducciones">Reproducciones</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Cuarentenas">Cuarentenas</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/HistorialesMedicos">Historiales Médicos</a></li>
                                </ul>
                            </li>

                            <!-- ══ SALUD ══ -->
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">Salud</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Diagnosticos">Diagnósticos</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Vacunaciones">Vacunaciones</a></li>
                                </ul>
                            </li>

                            <!-- ══ PERSONAL ══ -->
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">Personal</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Empleados">Empleados</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Gerentes">Gerentes</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Veterinarios">Veterinarios</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Entrenadores">Entrenadores</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/CuidadorAnimales">Cuidadores</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/PersonalAseo">Personal de Aseo</a></li>
                                </ul>
                            </li>

                            <!-- ══ VISITANTES ══ -->
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">Visitas</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Visitantes">Visitantes</a></li>
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Entradas">Entradas</a></li>
                                </ul>
                            </li>
                            <!-- SISTEMA -->
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">Sistema</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Ventanas/Auditorias">Auditorías</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    @if (Context.Session.GetString("UsuarioSede") != null)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <span class="nav-link text-muted">👤 @Context.Session.GetString("UsuarioSede")</span>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Zoológicos - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
