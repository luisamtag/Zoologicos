@page
@model Zoologicos_Presentacion.Pages.Ventanas.EspeciesModel

@{
    ViewData["Title"] = "Especies";
}

<div class="text-center">
    <form method="POST" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <h1 class="display-4">
            Catálogo de Especies
        </h1>

        <div class="bt_panel_buttons">
            <input type="submit" value="Refrescar" asp-page-handler="BtRefrescar" />
            <input type="submit" value="Nuevo" asp-page-handler="BtNuevo" />
            <input type="submit" value="Guardar" asp-page-handler="BtGuardar" />
        </div>

        @if (Model.Especie != null)
        {
            <div class="row justify-content-center text-left" style="text-align: left; margin-bottom: 20px;">
                <div class="col-lg-6">
                    
                    <div class="form-group">
                        <label>Tipo de Especie (Ej: Mamífero, Ave, Reptil)</label>
                        <input id="inTipo" class="cts_forms form-control" asp-for="@Model.Especie!.Tipo" required />
                    </div>

                    <div class="form-group">
                        <label>Descripción / Nombre de la Especie (Ej: León Africano, Pingüino de Humboldt)</label>
                        <textarea id="inDescripcion" class="cts_forms form-control" rows="3" asp-for="@Model.Especie!.Descripcion" required></textarea>
                    </div>
                    
                </div>
            </div>
        }

        @if (ViewData.ContainsKey("Mensaje"))
        {
            @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
            ;
        }
        
        @if (@Model.Especie != null && Model.Borrando)
        {
            <div class='popup'>
                <div class='pp_ms_inner'>
                    <div style='width:95%'>
                        <h2 align="left">Mensaje</h2>
                        <h4 align="left">¿Desea eliminar esta Especie del catálogo?</h4>
                        <h6 align="left">
                            <strong>Especie:</strong> @Model.Especie!.Descripcion <br />
                            <strong>Tipo:</strong> @Model.Especie!.Tipo
                        </h6>

                        <input type="hidden" asp-for="@Model.Especie!.Id" />
                        <input type="submit" value="Cerrar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                        <input type="submit" value="Borrar" asp-page-handler="BtBorrar" class="btn btn-danger" />
                    </div>
                </div>
            </div>
        }

        @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
        {
            <table class="tb_data table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tipo</th>
                        <th>Descripción / Nombre Científico o Común</th>
                        <th class="cl_actions">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.Id</td>
                            <td><span class="badge bg-secondary text-white">@elemento.Tipo</span></td>
                            <td><strong>@elemento.Descripcion</strong></td>
                            <td>
                                <input type="submit" value="Modificar" asp-page-handler="BtModificar" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </form>
</div>