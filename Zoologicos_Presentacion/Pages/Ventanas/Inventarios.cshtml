@page
@model Zoologicos_Presentacion.Pages.Ventanas.InventariosModel

@{
    ViewData["Title"] = "Control de Inventario";
}

<div class="text-center">
    <form method="POST" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <h1 class="display-4">
            Gestión de Inventario y Recursos
        </h1>

        <!-- Panel Principal de Botones -->
        <div class="bt_panel_buttons">
            <input type="submit" value="Refrescar" asp-page-handler="BtRefrescar" />
            <input type="submit" value="Nuevo" asp-page-handler="BtNuevo" />
            <input type="submit" value="Guardar" asp-page-handler="BtGuardar" />
        </div>

        <!-- Formulario de Edición / Creación -->
        @if (Model.Inventario != null)
        {
            <div class="row justify-content-center text-left" style="text-align: left; margin-bottom: 20px;">
                <div class="col-lg-6">
                    
                    <div class="form-group">
                        <label>Zoológico ID (Ubicación del Almacén)</label>
                        <input id="inZoologicoId" type="number" min="1" class="cts_forms form-control" asp-for="@Model.Inventario!.ZoologicoId" required />
                    </div>

                    <div class="form-group">
                        <label>Nombre del Artículo / Ítem</label>
                        <input id="inNombreItem" class="cts_forms form-control" asp-for="@Model.Inventario!.NombreItem" placeholder="Ej: Concentrado felinos, Vacuna triple" required />
                    </div>

                    <div class="form-group">
                        <label>Categoría / Tipo de Ítem</label>
                        <select id="inTipoItem" class="cts_forms form-control" asp-for="@Model.Inventario!.TipoItem" required>
                            <option value="">-- Seleccione Tipo --</option>
                            <option value="Alimento">Alimento / Nutrición</option>
                            <option value="Médico">Médico / Medicamento</option>
                            <option value="Mantenimiento">Herramientas / Mantenimiento</option>
                            <option value="Limpieza">Limpieza y Desinfección</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Cantidad Disponible</label>
                        <input id="inCantidad" type="number" step="0.01" min="0" class="cts_forms form-control" asp-for="@Model.Inventario!.CantidadDisponible" required />
                    </div>

                    <div class="form-group">
                        <label>Fecha de Vencimiento (Opcional)</label>
                        <input id="inFechaVencimiento" type="date" class="cts_forms form-control" asp-for="@Model.Inventario!.FechaVencimiento" />
                    </div>
                    
                </div>
            </div>
        }

        <!-- Zona de Alertas y Errores -->
        @if (ViewData.ContainsKey("Mensaje"))
        {
            @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
            ;
        }
        
        <!-- Popup de Confirmación de Borrado -->
        @if (@Model.Inventario != null && Model.Borrando)
        {
            <div class='popup'>
                <div class='pp_ms_inner'>
                    <div style='width:95%'>
                        <h2 align="left">Mensaje</h2>
                        <h4 align="left">¿Desea eliminar este ítem del inventario?</h4>
                        <h6 align="left">
                            <strong>Artículo:</strong> @Model.Inventario!.NombreItem <br />
                            <strong>Stock actual:</strong> @Model.Inventario!.CantidadDisponible
                        </h6>

                        <input type="submit" value="Cerrar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                        <input type="submit" value="Borrar" asp-page-handler="BtBorrar" class="btn btn-danger" />
                    </div>
                </div>
            </div>
        }

        <!-- Tabla de Datos Históricos -->
        @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
        {
            <table class="tb_data table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Sede ID</th>
                        <th>Nombre del Ítem</th>
                        <th>Tipo / Categoría</th>
                        <th>Cantidad Disponible</th>
                        <th>Fecha Vencimiento</th>
                        <th class="cl_actions">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.Id</td>
                            <td>Sede #@elemento.ZoologicoId</td>
                            <td><strong>📦 @elemento.NombreItem</strong></td>
                            <td>@elemento.TipoItem</td>
                            <td>@elemento.CantidadDisponible.ToString("N2")</td>
                            <td>
                                @if (elemento.FechaVencimiento.HasValue)
                                {
                                    <span class="@(elemento.FechaVencimiento.Value < DateTime.Today ? "text-danger font-weight-bold" : "")">
                                        @elemento.FechaVencimiento.Value.ToString("dd/MM/yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">No aplica ♾️</span>
                                }
                            </td>
                            <td>
                                <input type="submit" value="Modificar" asp-page-handler="BtModificar" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </form>
</div>