@page
@model Zoologicos_Presentacion.Pages.Ventanas.VisitantesModel

@{
    ViewData["Title"] = "Registro de Visitantes";
}

<div class="text-center">
    <form method="POST" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <h1 class="display-4">
            Control y Registro de Visitantes
        </h1>

        <div class="bt_panel_buttons">
            <input type="submit" value="Refrescar" asp-page-handler="BtRefrescar" />
            <input type="submit" value="Nuevo" asp-page-handler="BtNuevo" />
            <input type="submit" value="Guardar" asp-page-handler="BtGuardar" />
        </div>

        @if (Model.Visitante != null)
        {
            <div class="row justify-content-center text-left" style="text-align: left; margin-bottom: 20px;">
                <div class="col-lg-6">
                    
                    <div class="form-group">
                        <label>Nombre Completo</label>
                        <input id="inNombre" class="cts_forms form-control" asp-for="@Model.Visitante!.Nombre" placeholder="Ej: Juan Pérez" required />
                    </div>

                    <div class="form-group">
                        <label>Tipo de Documento</label>
                        <select id="inTipoDocumento" class="cts_forms form-control" asp-for="@Model.Visitante!.TipoDocumento" required>
                            <option value="">-- Seleccione Tipo --</option>
                            <option value="CC">Cédula de Ciudadanía (CC)</option>
                            <option value="TI">Tarjeta de Identidad (TI)</option>
                            <option value="CE">Cédula de Extranjería (CE)</option>
                            <option value="Pasaporte">Pasaporte</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Número de Documento</label>
                        <input id="inNumeroDocumento" class="cts_forms form-control" asp-for="@Model.Visitante!.NumeroDocumento" placeholder="Ej: 1045321..." required />
                    </div>
                    
                </div>
            </div>
        }

        @if (ViewData.ContainsKey("Mensaje"))
        {
            @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
            ;
        }
        
        @if (@Model.Visitante != null && Model.Borrando)
        {
            <div class='popup'>
                <div class='pp_ms_inner'>
                    <div style='width:95%'>
                        <h2 align="left">Mensaje</h2>
                        <h4 align="left">¿Desea eliminar el registro de este visitante?</h4>
                        <h6 align="left">
                            <strong>Visitante:</strong> @Model.Visitante!.Nombre <br />
                            <strong>Documento:</strong> @Model.Visitante!.TipoDocumento @Model.Visitante!.NumeroDocumento
                        </h6>

                        <input type="hidden" asp-for="@Model.Visitante!.Id" />
                        <input type="submit" value="Cerrar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                        <input type="submit" value="Borrar" asp-page-handler="BtBorrar" class="btn btn-danger" />
                    </div>
                </div>
            </div>
        }

        @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
        {
            <table class="tb_data table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>ID Reg.</th>
                        <th>Nombre Completo</th>
                        <th>Tipo Doc.</th>
                        <th>Número Documento</th>
                        <th class="cl_actions">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>👤 #@elemento.Id</td>
                            <td><strong>@elemento.Nombre</strong></td>
                            <td><span class="badge bg-secondary">@elemento.TipoDocumento</span></td>
                            <td>@elemento.NumeroDocumento</td>
                            <td>
                                <input type="submit" value="Modificar" asp-page-handler="BtModificar" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </form>
</div>