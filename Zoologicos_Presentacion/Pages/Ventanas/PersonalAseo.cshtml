@page
@model Zoologicos_Presentacion.Pages.Ventanas.PersonalAseoModel

@{
    ViewData["Title"] = "Personal de Aseo y Sanitización";
}

<div class="text-center">
    <form method="POST" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <h1 class="display-4">
            Gestión de Personal de Aseo
        </h1>

        <!-- Panel Principal de Botones -->
        <div class="bt_panel_buttons">
            <input type="submit" value="Refrescar" asp-page-handler="BtRefrescar" />
            <input type="submit" value="Nuevo" asp-page-handler="BtNuevo" />
            <input type="submit" value="Guardar" asp-page-handler="BtGuardar" />
        </div>

        <!-- Formulario de Edición / Creación -->
        @if (Model.Personal != null)
        {
            <div class="row justify-content-center text-left" style="text-align: left; margin-bottom: 20px;">
                <div class="col-lg-6">
                    
                    <!-- Nota: Los campos heredados de Empleados (Nombre, Cedula, etc.) se omiten o se asumen integrados en el flujo -->

                    <div class="form-group">
                        <label>Zona o Sector Asignado</label>
                        <input id="inZonaAsignada" class="cts_forms form-control" asp-for="@Model.Personal!.ZonaAsignada" placeholder="Ej: Zona Norte - Aviarios, Serpentario" required />
                    </div>

                    <div class="form-group">
                        <label>Turno de Trabajo</label>
                        <input id="inTurno" class="cts_forms form-control" asp-for="@Model.Personal!.Turno" list="turnosSugeridos" placeholder="Escriba o seleccione un turno..." required />
                        <datalist id="turnosSugeridos">
                            <option value="Mañana" />
                            <option value="Tarde" />
                            <option value="Noche" />
                        </datalist>
                    </div>

                    <div class="form-group">
                        <label>Kits de Productos e Insumos Asignados</label>
                        <textarea id="inProductos" class="cts_forms form-control" rows="3" asp-for="@Model.Personal!.ProductosAsignados" placeholder="Ej: Desinfectante industrial, Amonio cuaternario, Paños microfibra" required></textarea>
                    </div>
                    
                </div>
            </div>
        }

        <!-- Zona de Alertas y Errores -->
        @if (ViewData.ContainsKey("Mensaje"))
        {
            @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
        }
        
        <!-- Popup de Confirmación de Borrado -->
        @if (@Model.Personal != null && Model.Borrando)
        {
            <div class='popup'>
                <div class='pp_ms_inner'>
                    <div style='width:95%'>
                        <h2 align="left">Mensaje</h2>
                        <h4 align="left">¿Desea dar de baja a este empleado de aseo?</h4>
                        <h6 align="left">
                            <strong>Empleado ID:</strong> @Model.Personal!.Id <br />
                            <strong>Zona que cubría:</strong> @Model.Personal!.ZonaAsignada
                        </h6>

                        <input type="submit" value="Cerrar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                        <input type="submit" value="Borrar" asp-page-handler="BtBorrar" class="btn btn-danger" />
                    </div>
                </div>
            </div>
        }

        <!-- Tabla de Datos Históricos -->
        @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
        {
            <table class="tb_data table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>ID Reg.</th>
                        <th>Zona Asignada</th>
                        <th>Turno</th>
                        <th>Insumos / Productos</th>
                        <th class="cl_actions">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>🧹 #@elemento.Id</td>
                            <td><strong>@elemento.ZonaAsignada</strong></td>
                            <td>
                                <span class="badge @(elemento.Turno == "Mañana" ? "bg-success text-white" : elemento.Turno == "Tarde" ? "bg-warning text-dark" : "bg-dark text-white")">
                                    @elemento.Turno
                                </span>
                            </td>
                            <td>
                                @(elemento.ProductosAsignados.Length > 45 ? elemento.ProductosAsignados.Substring(0, 45) + "..." : elemento.ProductosAsignados)
                            </td>
                            <td>
                                <input type="submit" value="Modificar" asp-page-handler="BtModificar" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </form>
</div>