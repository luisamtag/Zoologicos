@page
@model Zoologicos_Presentacion.Pages.Ventanas.HabitatsModel

@{
    ViewData["Title"] = "Hábitats";
}

<div class="text-center">
    <form method="POST" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <h1 class="display-4">
            Gestión de Hábitats
        </h1>

        <!-- Panel Principal de Botones -->
        <div class="bt_panel_buttons">
            <input type="submit" value="Refrescar" asp-page-handler="BtRefrescar" />
            <input type="submit" value="Nuevo" asp-page-handler="BtNuevo" />
            <input type="submit" value="Guardar" asp-page-handler="BtGuardar" />
        </div>

        <!-- Formulario de Edición / Creación -->
        @if (Model.Habitat != null)
        {
            <div class="row justify-content-center text-left" style="text-align: left; margin-bottom: 20px;">
                <div class="col-lg-6">
                    
                    <div class="form-group">
                        <label>Nombre del Hábitat</label>
                        <input id="inNombre" class="cts_forms form-control" asp-for="@Model.Habitat!.Nombre" placeholder="Ej: Sabana Africana, Aviario Principal" required />
                    </div>

                    <div class="form-group">
                        <label>Tipo de Bioma / Ambiente</label>
                        <input id="inTipo" class="cts_forms form-control" asp-for="@Model.Habitat!.Tipo" list="biomasSugeridos" placeholder="Escriba o seleccione un bioma..." required />
                        <datalist id="biomasSugeridos">
                            <option value="Terrestre" />
                            <option value="Acuático" />
                            <option value="Desértico" />
                            <option value="Tundra" />
                            <option value="Selva Húmeda" />
                            <option value="Aviario" />
                        </datalist>
                    </div>

                    <div class="form-group">
                        <label>Capacidad Máxima de Ejemplares</label>
                        <input id="inCapacidad" type="number" min="1" class="cts_forms form-control" asp-for="@Model.Habitat!.CapacidadMaxima" placeholder="Ej: 15" required />
                    </div>

                    <div class="form-group">
                        <label>Estado del Hábitat</label>
                        <input id="inEstado" class="cts_forms form-control" asp-for="@Model.Habitat!.Estado" list="estadosSugeridos" placeholder="Escriba o seleccione un estado..." required />
                        <datalist id="estadosSugeridos">
                            <option value="Excelente" />
                            <option value="En Mantenimiento" />
                            <option value="Cuarentena" />
                            <option value="Restricción Parcial" />
                        </datalist>
                    </div>

                    <div class="form-group">
                        <label>Zoológico ID (Ubicación Sede)</label>
                        <input id="inZoologicoId" type="number" min="1" class="cts_forms form-control" asp-for="@Model.Habitat!.ZoologicoId" placeholder="Ej: 1" required />
                    </div>
                    
                </div>
            </div>
        }

        <!-- Zona de Alertas y Errores -->
        @if (ViewData.ContainsKey("Mensaje"))
        {
            @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
        }
        
        <!-- Popup de Confirmación de Borrado -->
        @if (@Model.Habitat != null && Model.Borrando)
        {
            <div class='popup'>
                <div class='pp_ms_inner'>
                    <div style='width:95%'>
                        <h2 align="left">Mensaje</h2>
                        <h4 align="left">¿Desea dar de baja o eliminar este Hábitat?</h4>
                        <h6 align="left">
                            <strong>Hábitat:</strong> @Model.Habitat!.Nombre <br />
                            <strong>Tipo:</strong> @Model.Habitat!.Tipo
                        </h6>

                        <input type="submit" value="Cerrar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                        <input type="submit" value="Borrar" asp-page-handler="BtBorrar" class="btn btn-danger" />
                    </div>
                </div>
            </div>
        }

        <!-- Tabla de Datos Históricos -->
        @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
        {
            <table class="tb_data table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>ID Reg.</th>
                        <th>Nombre</th>
                        <th>Tipo / Bioma</th>
                        <th>Capacidad Máx.</th>
                        <th>Estado</th>
                        <th class="cl_hidden">Zoológico Sede</th>
                        <th class="cl_actions">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>🌿 #@elemento.Id</td>
                            <td><strong>@elemento.Nombre</strong></td>
                            <td>@elemento.Tipo</td>
                            <td>@elemento.CapacidadMaxima animales</td>
                            <td>
                                <span class="badge @(elemento.Estado.ToLower().Contains("mantenimiento") ? "bg-warning text-dark" : elemento.Estado.ToLower().Contains("cuarentena") ? "bg-danger text-white" : "bg-success text-white")">
                                    @elemento.Estado
                                </span>
                            </td>
                            <td class="cl_hidden">Sede #@elemento.ZoologicoId</td>
                            <td>
                                <input type="submit" value="Modificar" asp-page-handler="BtModificar" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </form>
</div>