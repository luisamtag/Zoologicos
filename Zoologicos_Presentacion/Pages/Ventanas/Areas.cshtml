@page
@model Zoologicos_Presentacion.Pages.Ventanas.AreasModel

@{
    ViewData["Title"] = "Áreas";
}

<div class="text-center">
    <form method="POST" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <h1 class="display-4">
            Gestión de Áreas
        </h1>

        <div class="bt_panel_buttons">
            <input type="submit" value="Refrescar" asp-page-handler="BtRefrescar" />
            <input type="submit" value="Nuevo" asp-page-handler="BtNuevo" />
            <input type="submit" value="Guardar" asp-page-handler="BtGuardar" />
        </div>

        @if (Model.Area != null)
        {
            <div class="row justify-content-center text-left" style="text-align: left; margin-bottom: 20px;">
                <div class="col-lg-6">
                    
                    <div class="form-group">
                        <label>ID Hábitat (Opcional)</label>
                        <input id="inHabitatId" type="number" class="cts_forms form-control" asp-for="@Model.Area!.HabitatId" />
                    </div>

                    <div class="form-group">
                        <label>ID Jaula (Opcional)</label>
                        <input id="inJaulaId" type="number" class="cts_forms form-control" asp-for="@Model.Area!.JaulaId" />
                    </div>

                    <div class="form-group">
                        <label>ID Zona Pública (Opcional)</label>
                        <input id="inZonaPublicaId" type="number" class="cts_forms form-control" asp-for="@Model.Area!.ZonaPublicaId" />
                    </div>
                    
                </div>
            </div>
        }

        @if (ViewData.ContainsKey("Mensaje"))
        {
            @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
            ;
        }
        
        @if (@Model.Area != null && Model.Borrando)
        {
            <div class='popup'>
                <div class='pp_ms_inner'>
                    <div style='width:95%'>
                        <h2 align="left">Mensaje</h2>
                        <h4 align="left">¿Desea borrar esta Área?</h4>
                        <h6 align="left">
                            <strong>Área ID:</strong> @Model.Area!.Id
                        </h6>

                        <input type="hidden" asp-for="@Model.Area!.Id" />
                        <input type="submit" value="Cerrar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                        <input type="submit" value="Borrar" asp-page-handler="BtBorrar" class="btn btn-danger" />
                    </div>
                </div>
            </div>
        }

        @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
        {
            <table class="tb_data table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>ID Área</th>
                        <th class="cl_hidden">ID Hábitat</th>
                        <th class="cl_hidden">ID Jaula</th>
                        <th class="cl_hidden">ID Zona Pública</th>
                        <th class="cl_actions">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.Id</td>
                            <td class="cl_hidden">@(elemento.HabitatId?.ToString() ?? "-")</td>
                            <td class="cl_hidden">@(elemento.JaulaId?.ToString() ?? "-")</td>
                            <td class="cl_hidden">@(elemento.ZonaPublicaId?.ToString() ?? "-")</td>
                            <td>
                                <input type="submit" value="Modificar" asp-page-handler="BtModificar" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </form>
</div>