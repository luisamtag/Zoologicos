@page
@model Zoologicos_Presentacion.Pages.Ventanas.ZonasPublicasModel

@{
    ViewData["Title"] = "Áreas y Zonas Públicas";
}

<div class="text-center">
    <form method="POST" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <h1 class="display-4">
            Gestión de Zonas Públicas
        </h1>

        <div class="bt_panel_buttons">
            <input type="submit" value="Refrescar" asp-page-handler="BtRefrescar" />
            <input type="submit" value="Nuevo" asp-page-handler="BtNuevo" />
            <input type="submit" value="Guardar" asp-page-handler="BtGuardar" />
        </div>

        @if (Model.ZonaPublica != null)
        {
            <div class="row justify-content-center text-left" style="text-align: left; margin-bottom: 20px;">
                <div class="col-lg-6">
                    
                    <div class="form-group">
                        <label>Nombre de la Zona</label>
                        <input id="inNombre" class="cts_forms form-control" asp-for="@Model.ZonaPublica!.Nombre" placeholder="Ej: Plazoleta de Comidas Central, Cafetería Sur" required />
                    </div>

                    <div class="form-group">
                        <label>Tipo de Zona Pública</label>
                        <input id="inTipo" class="cts_forms form-control" asp-for="@Model.ZonaPublica!.Tipo" list="tiposZonaSugeridos" placeholder="Escriba o seleccione un tipo de zona..." required />
                        <datalist id="tiposZonaSugeridos">
                            <option value="Restaurante / Cafetería" />
                            <option value="Baños / Servicios" />
                            <option value="Mirador / Descanso" />
                            <option value="Tienda de Recuerdos" />
                            <option value="Zona Infantil / Juegos" />
                            <option value="Enfermería / Primeros Auxilios" />
                        </datalist>
                    </div>

                    <div class="form-group">
                        <label>Zoológico ID (Sede Vinculada)</label>
                        <input id="inZoologicoId" type="number" min="1" class="cts_forms form-control" asp-for="@Model.ZonaPublica!.ZoologicoId" placeholder="Ej: 1" required />
                    </div>
                    
                </div>
            </div>
        }

        <!-- Zona de Alertas y Errores -->
        @if (ViewData.ContainsKey("Mensaje"))
        {
            @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
        }
        
        <!-- Popup de Confirmación de Borrado -->
        @if (@Model.ZonaPublica != null && Model.Borrando)
        {
            <div class='popup'>
                <div class='pp_ms_inner'>
                    <div style='width:95%'>
                        <h2 align="left">Mensaje</h2>
                        <h4 align="left">¿Desea eliminar esta zona pública del sistema?</h4>
                        <h6 align="left">
                            <strong>Zona:</strong> @Model.ZonaPublica!.Nombre <br />
                            <strong>Tipo:</strong> @Model.ZonaPublica!.Tipo
                        </h6>

                        <input type="submit" value="Cerrar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                        <input type="submit" value="Borrar" asp-page-handler="BtBorrar" class="btn btn-danger" />
                    </div>
                </div>
            </div>
        }

        <!-- Tabla de Datos Históricos -->
        @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
        {
            <table class="tb_data table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>ID Reg.</th>
                        <th>Nombre de la Zona</th>
                        <th>Tipo / Categoría</th>
                        <th>Zoológico Sede ID</th>
                        <th class="cl_actions">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>📍 #@elemento.Id</td>
                            <td><strong>@elemento.Nombre</strong></td>
                            <td>@elemento.Tipo</td>
                            <td>Sede #@elemento.ZoologicoId</td>
                            <td>
                                <input type="submit" value="Modificar" asp-page-handler="BtModificar" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                                <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal" class="btn btn-secondary btn-sm" asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </form>
</div>