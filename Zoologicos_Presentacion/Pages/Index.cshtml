@page
@model Zoologicos_Presentacion.Pages.IndexModel

@{
    ViewData["Title"] = "Portal de Acceso";
}

<div class="text-center">
    <form method="POST" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        @if (!Model.EstaLogueado)
        {
            <div class="login-wrapper">
                <div class="login-card" style="max-width: 450px; margin: 40px auto; padding: 30px; border: 1px solid #ddd; border-radius: 8px; background: #fff;">
                    
                    <h2 class="login-title">🔑 Acceso al Sistema</h2>
                    <p class="text-muted">Control de Operaciones e Inventario Zoológico</p>

                    <div class="form-group mb-3" style="text-align: left;">
                        <label class="form-label">Usuario / Identificador</label>
                        <input type="text" asp-for="@Model.Usuario" class="form-control cts_forms" placeholder="Ej: admin" required />
                    </div>

                    <div class="form-group mb-4" style="text-align: left;">
                        <label class="form-label">Contraseña de Seguridad</label>
                        <input type="password" asp-for="@Model.Contrasena" class="form-control cts_forms" placeholder="••••••••" required />
                    </div>

                    <div class="text-center">
                        <input type="submit" value="Limpiar" asp-page-handler="BtClean" class="btn btn-secondary me-2" />
                        <input type="submit" value="Entrar al Sistema" asp-page-handler="BtEnter" class="btn btn-primary" />
                    </div>

                </div>
            </div>
        }
        else
        {
            <div class="jumbotron mt-5" style="padding: 40px; background-color: #f8f9fa; border-radius: 10px;">
                <h1 class="display-4">🐾 ¡Bienvenido al Panel de Control!</h1>
                <p class="lead">Sesión activa como administrador del Parque Zoológico.</p>
                <hr class="my-4">
                <p class="text-muted">Utilice el menú superior para navegar por los módulos de vacunación, reproducción y zonas públicas.</p>
                
                <div class="mt-4">
                    <input type="submit" value="Cerrar Sesión Segura" asp-page-handler="BtClose" class="btn btn-danger" />
                </div>
            </div>
        }

        @if (ViewData.ContainsKey("Mensaje"))
        {
            @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
        }
    </form>
</div>
